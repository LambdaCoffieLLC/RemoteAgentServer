{
  "name": "@remote-agent-server/web",
  "private": true,
  "type": "module",
  "main": "dist/lib/index.js",
  "types": "dist/lib/index.d.ts",
  "files": ["dist"],
  "dependencies": {
    "@remote-agent-server/auth": "workspace:*",
    "@remote-agent-server/ports": "workspace:*",
    "@remote-agent-server/protocol": "workspace:*",
    "@remote-agent-server/providers": "workspace:*",
    "@remote-agent-server/sessions": "workspace:*",
    "@remote-agent-server/ui": "workspace:*"
  },
  "devDependencies": {
    "vite": "^7.1.7"
  },
  "scripts": {
    "build": "tsc -p tsconfig.lib.json && tsc -p tsconfig.json --noEmit && vite build",
    "dev": "vite",
    "lint": "eslint src --ext .ts",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
