{
  "name": "@remote-agent-server/desktop",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "dependencies": {
    "@remote-agent-server/auth": "workspace:*",
    "@remote-agent-server/ports": "workspace:*",
    "@remote-agent-server/protocol": "workspace:*",
    "@remote-agent-server/providers": "workspace:*",
    "@remote-agent-server/sessions": "workspace:*",
    "@remote-agent-server/ui": "workspace:*"
  },
  "devDependencies": {
    "electron": "^37.2.6"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node ./scripts/ensure-electron.mjs && pnpm build && electron dist/main.js",
    "lint": "eslint src --ext .ts",
    "start": "node ./scripts/ensure-electron.mjs && pnpm build && electron dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
