{
  "name": "remote-agent-server",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm -r --filter \"@remote-agent-server/*\" build",
    "lint": "pnpm run lint:repo && pnpm -r --filter \"@remote-agent-server/*\" lint",
    "typecheck": "pnpm run typecheck:repo && pnpm -r --filter \"@remote-agent-server/*\" typecheck",
    "test": "pnpm run test:repo && pnpm run test:ralph",
    "verify": "pnpm lint && pnpm build && pnpm typecheck && pnpm test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:repo": "eslint .agents/ralph tests --ext .ts",
    "typecheck:repo": "tsc -p tsconfig.json --noEmit",
    "test:repo": "node --import tsx --test tests/**/*.test.ts",
    "test:ralph": "node --import tsx --test .agents/ralph/tests/*.test.ts",
    "verify:ralph": "pnpm verify",
    "ralph": "node --import tsx .agents/ralph/ralph.ts",
    "ralph:danger": "RALPH_CODEX_BYPASS=true node --import tsx .agents/ralph/ralph.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/node": "^24.5.2",
    "eslint": "^9.36.0",
    "globals": "^16.4.0",
    "prettier": "^3.6.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.44.1"
  }
}
