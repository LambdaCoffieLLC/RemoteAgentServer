{
  "name": "remote-agent-server",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm -r run build",
    "lint": "pnpm run lint:root && pnpm -r run lint",
    "lint:root": "eslint .agents/ralph/**/*.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "ralph": "node --import tsx .agents/ralph/ralph.ts",
    "ralph:danger": "RALPH_CODEX_BYPASS=true node --import tsx .agents/ralph/ralph.ts",
    "test": "node --import tsx --test .agents/ralph/tests/*.test.ts",
    "typecheck": "pnpm run typecheck:root && pnpm -r run typecheck",
    "typecheck:root": "tsc -p tsconfig.json --noEmit",
    "verify:ralph": "pnpm test && pnpm build && pnpm lint && pnpm typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/node": "^24.5.2",
    "@typescript-eslint/eslint-plugin": "^8.44.1",
    "@typescript-eslint/parser": "^8.44.1",
    "eslint": "^9.36.0",
    "globals": "^16.4.0",
    "prettier": "^3.6.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
