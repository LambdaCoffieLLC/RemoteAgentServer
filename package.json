{
  "name": "remote-agent-server",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "ralph": "node --import tsx .agents/ralph/ralph.ts",
    "ralph:clean": "node scripts/ralph-clean.mjs",
    "ralph:clean:all": "node scripts/ralph-clean.mjs --include-node-modules",
    "ralph:danger": "RALPH_CODEX_BYPASS=true node --import tsx .agents/ralph/ralph.ts",
    "ralph:worktree": "node scripts/ralph-worktree.mjs",
    "ralph:worktree:path": "node scripts/ralph-worktree.mjs --print-path",
    "test": "node --import tsx --test .agents/ralph/tests/*.test.ts",
    "verify:ralph": "pnpm test && pnpm exec tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
