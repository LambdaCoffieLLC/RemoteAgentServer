{
  "name": "@remote-agent-server/runtime",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "main": "dist/index.js",
  "types": "src/index.ts",
  "bin": {
    "remote-agent-runtime": "dist/cli.js"
  },
  "files": ["dist", "scripts/install-linux-runtime.sh"],
  "dependencies": {
    "@remote-agent-server/auth": "workspace:*",
    "@remote-agent-server/ports": "workspace:*",
    "@remote-agent-server/protocol": "workspace:*",
    "@remote-agent-server/providers": "workspace:*",
    "@remote-agent-server/sessions": "workspace:*"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
